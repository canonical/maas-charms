{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": ["every week"],
  "ignoreDeps": [
    "canonical/operator-workflows",
    "tj-actions/changed-files"
  ],
  "packageRules": [
    {
      "description": "Update botocore and boto3 together",
      "matchPackageNames": ["botocore", "boto3"],
      "groupName": "botocore"
    }
  ],
  "description": [
    "Uncomment the block below to batch all updates into a single weekly PR:",
    "{\"groupName\": \"weekly dependencies\", \"matchPackageNames\": [\"*\"], \"schedule\": [\"every week\"]}"
  ]
}
